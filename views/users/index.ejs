<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Users</title>

    <link rel="stylesheet" href="/css/users.css">
</head>

<body>

    <div class="users-page">

        <div class="users-header">
            <h2>👥 Users Management</h2>
            <a href="/users/add" class="add-btn">+ Add User</a>
        </div>

        <div class="table-container">
            <table class="users-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    <% users.forEach(user=> { %>
                        <tr>
                            <td>
                                <%= user.name %>
                            </td>
                            <td>
                                <%= user.email %>
                            </td>
                            <td class="role">
                                <%= user.role %>
                            </td>
                            <td>
                                <a href="/users/<%= user._id %>/edit" class="edit">Edit</a>
                                <a href="/users/<%= user._id %>/delete" class="delete">Delete</a>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
        </div>

    </div>

</body>

</html>